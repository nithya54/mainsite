{
  "rewrites": [
    {
      "source": "/app1",
      "destination": "https://myvercelwebsite-dusky.vercel.app"
    },
    {
      "source": "/app1/(.*)",
      "destination": "https://myvercelwebsite-dusky.vercel.app/$1"
    },
    {
      "source": "/app2",
      "destination": "https://taskapp-sooty.vercel.app"
    },
    {
      "source": "/app2/(.*)",
      "destination": "https://taskapp-sooty.vercel.app/$1"
    }
  ],
  "functions": {
    "pages/api/edge/route.js": {
      "runtime": "edge"
    }
  }
}